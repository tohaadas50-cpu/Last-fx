{
  "compilerOptions": {
    "target":            "ES2019",
    "module":            "commonjs",
    "lib":               ["ES2019"],
    "rootDir":           "src",
    "outDir":            "dist",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "resolveJsonModule": true,
    "sourceMap":         false,
    "declaration":       false,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

