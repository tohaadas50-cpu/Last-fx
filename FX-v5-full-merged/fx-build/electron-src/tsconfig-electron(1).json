{
  "compilerOptions": {
    "target":            "ES2019",
    "module":            "commonjs",
    "lib":               ["ES2019"],
    "rootDir":           ".",
    "outDir":            "../electron",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "resolveJsonModule": true,
    "sourceMap":         false,
    "declaration":       false
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
