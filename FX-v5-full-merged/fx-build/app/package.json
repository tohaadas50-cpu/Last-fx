{
  "name": "textfx-app",
  "version": "0.2.0",
  "private": true,
  "engines": { "node": ">=18", "npm": ">=9" },
  "scripts": {
    "dev":           "vite",
    "build":         "vite build",
    "preview":       "vite preview",
    "typecheck":     "tsc --noEmit",
    "cap:add-android": "npx cap add android",
