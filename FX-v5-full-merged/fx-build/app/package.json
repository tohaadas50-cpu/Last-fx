    "mobile":        "npm run build && npx cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core":    "^6.0.0",
    "jspdf":              "^3.0.4",
    "react":              "^18.3.1",
    "react-dom":          "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli":       "^6.0.0",
    "@types/react":         "^18.3.3",
    "@types/react-dom":     "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript":           "^5.4.5",
    "vite":                 "^5.3.1"
  }
}
